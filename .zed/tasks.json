[
  {
    "label": "PySide: 编译资源文件 (RCC)",
    "command": "uv",
    "args": [
      "run",
      "pyside6-rcc",
      "src/ferret/resources/resources.qrc",
      "-o",
      "src/ferret/config/resources_rc.py",
    ],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
  {
    "label": "启动 App",
    "command": "uv",
    "args": ["run", "python", "-m", "ferret"],
    "env": {
      "PYTHONPATH": "src",
    },
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
  },
]
